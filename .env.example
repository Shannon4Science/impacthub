# LLM / Search API
LLM_API_BASE=https://api.openai.com/v1
LLM_API_KEY=your-api-key-here
LLM_BUZZ_MODEL=gpt-5
LLM_FALLBACK_MODEL=gpt-5-mini

# Advisor crawler LLM override. Leave empty/default to reuse LLM_API_*.
# Set provider=anthropic for Anthropic-compatible /v1/messages endpoints.
LLM_CRAWL_PROVIDER=openai
LLM_CRAWL_API_BASE=
LLM_CRAWL_API_KEY=
LLM_CRAWL_MODEL=
LLM_CRAWL_THINKING=off
LLM_CRAWL_PROMPT_PROFILE=default

# Outbound proxy (optional, for restricted network environments)
OUTBOUND_PROXY=

# GitHub token (optional, for higher rate limits)
GITHUB_TOKEN=

# Recommendation system
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_EMBEDDING_MODEL=text-embedding-v4
DASHSCOPE_EMBEDDING_DIMENSIONS=1024
MINERU_PATH=mineru
RECOMMENDATION_TOP_N=3

# Xiaohongshu recruitment crawler
TIKHUB_API_KEY=
ANTHROPIC_API_KEY=
