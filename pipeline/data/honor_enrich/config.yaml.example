# api_tool 配置：批量查询学者荣誉
# 复制为 config.yaml 后填入真实 API key
api:
  api_key: "your-api-key-here"
  base_url: "https://api.openai.com/v1"

model:
  model: "gemini-3-pro-preview"
  temperature: 0.2
  top_p: 0.9
  max_tokens: 2048
  stream: true
  thinking: false

concurrency:
  concurrency: 30
  rpm: 600
  timeout: 120
  retry: 1
  write_interval: 10

io:
  input_file: "./input.jsonl"
  output_dir: "./output/"
  prompt_file: "./prompt.txt"
  key_name: "scholar_id"
  kept_columns: ["name", "affiliation", "cn", "direction", "tier"]
